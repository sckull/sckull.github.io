&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;      &lt;span class=&#34;c1&#34;&gt;#- &amp;#39;127.0.0.1:5022:22&amp;#39;&lt;/span&gt;
